# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bollywood_real
DB_USER=root
DB_PASS=yourpassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# OTP (Fast2SMS - free tier for India)
# Sign up at https://www.fast2sms.com/ - free credits on signup
FAST2SMS_API_KEY=your_fast2sms_api_key

# For dev: set to "true" to skip real SMS and log OTP to console
OTP_DEV_MODE=true

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Admin credentials (for first-time setup)
ADMIN_PHONE=9999999999
ADMIN_NAME=Admin

# Google AdSense (add your publisher ID when ready)
ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXXX
